// File name: projects/1/And.hdl
/**
 * And gate:
 * if (a and b) out = 1, else out = 0 
 */
CHIP And {
    IN a, b;
    OUT out;
    
    PARTS:
    //The truth table of the And gate is the opposite of the Nand
    //So, the And gate can be implemented by adding a Not gate after the Nand gate
    Nand(a=a, b=b, out=nandout);
    Not(in=nandout, out=out);
}